# ==============================================================================
# Student Helpdesk Agent — Production & Docker Environment Configuration
# ==============================================================================
# Copy this file to .env before running Docker Compose or publishing online.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. MongoDB Database Connection
# ------------------------------------------------------------------------------
# Option A: Online MongoDB Cloud (MongoDB Atlas) - RECOMMENDED FOR PUBLISHING
# Paste your MongoDB Atlas cloud connection string below:
# MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.mongodb.net/student_helpdesk?retryWrites=true&w=majority"
#
# Option B: Local Docker MongoDB Container (Default)
# If MONGODB_URI is left blank or commented out, Docker Compose automatically
# connects to the internal persistent MongoDB database container on port 27017:
MONGODB_URI="mongodb://mongodb:27017/student_helpdesk"

# ------------------------------------------------------------------------------
# 2. Application & Server Configuration
# ------------------------------------------------------------------------------
NODE_ENV=production
PORT=5000
CLIENT_URL="http://localhost:80"

# ------------------------------------------------------------------------------
# 3. Security & Authentication
# ------------------------------------------------------------------------------
JWT_SECRET="enterprise-super-secret-jwt-key-2026-xyzec"
JWT_EXPIRE="7d"

# ------------------------------------------------------------------------------
# 4. AI & Chat Integration (xAI Grok / OpenAI / Mock AI)
# ------------------------------------------------------------------------------
# Add your xAI Grok API key here for live generative responses in the Helpdesk
GROK_API_KEY=""
GROK_MODEL="grok-beta"
